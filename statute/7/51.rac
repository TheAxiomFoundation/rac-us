        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 1_756

    - name: "Ten person - zero income (beyond schedule)"
      period: 2024-01
      inputs:
        household_size: 10
        gross_income: 0
        earned_income: 0
        shelter_costs: 0
        has_elderly_disabled: false
        bank_accounts: 0
        cash_on_hand: 0
        stocks: 0
        bonds: 0
        other_financial_assets: 0
        vehicle_fair_market_value: 0
        receives_ssi: false
        receives_tanf: false
        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 2_196

    - name: "Large household with moderate income"
      period: 2024-01
      inputs:
        household_size: 8
        gross_income: 3_000
        earned_income: 3_000
        shelter_costs: 1_400
        has_elderly_disabled: false
        bank_accounts: 0
        cash_on_hand: 0
        stocks: 0
        bonds: 0
        other_financial_assets: 0
        vehicle_fair_market_value: 0
        receives_ssi: false
        receives_tanf: false
        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 1_256

    # ============================================================
    # Resource Threshold Tests
    # ============================================================
    - name: "At resource limit - regular household"
      period: 2024-01
      inputs:
        household_size: 2
        gross_income: 800
        earned_income: 800
        shelter_costs: 600
        has_elderly_disabled: false
        bank_accounts: 2_750
        cash_on_hand: 0
        stocks: 0
        bonds: 0
        other_financial_assets: 0
