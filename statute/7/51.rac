        receives_tanf: false
        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 0

    - name: "Net income at FPL threshold"
      period: 2024-01
      inputs:
        household_size: 2
        gross_income: 2_100
        earned_income: 2_000
        shelter_costs: 800
        has_elderly_disabled: false
        bank_accounts: 0
