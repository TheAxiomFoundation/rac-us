        receives_tanf: false
        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 0

    # ============================================================
    # Income Threshold Tests - Gross Income
    # ============================================================
    - name: "Single person at 130% FPL gross income limit"
      period: 2024-01
      inputs:
        household_size: 1
        gross_income: 1_631
        earned_income: 1_500
        shelter_costs: 800
