        receives_tanf: false
        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 1_390

    - name: "Eight person - zero income - maximum benefit"
      period: 2024-01
      inputs:
        household_size: 8
        gross_income: 0
        earned_income: 0
        shelter_costs: 0
