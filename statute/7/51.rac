        medical_expenses: 0
      expect: 536

    - name: "Exceeds higher resource limit - elderly/disabled"
      period: 2024-01
      inputs:
        household_size: 2
        gross_income: 800
        earned_income: 0
        shelter_costs: 1_000
        has_elderly_disabled: true
