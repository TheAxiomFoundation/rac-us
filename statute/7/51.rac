        medical_expenses: 0
      expect: 23

    # ============================================================
    # Income Threshold Tests - Net Income
    # ============================================================
    - name: "Passes gross but fails net income test"
      period: 2024-01
      inputs:
        household_size: 1
        gross_income: 1_500
