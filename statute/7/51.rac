        bank_accounts: 0
        cash_on_hand: 0
        stocks: 0
        bonds: 0
        other_financial_assets: 0
        vehicle_fair_market_value: 0
        receives_ssi: false
        receives_tanf: false
        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 975

    - name: "Family of 4 - working poor"
      period: 2024-01
      inputs:
        household_size: 4
        gross_income: 1_500
        earned_income: 1_500
        shelter_costs: 900
        has_elderly_disabled: false
        bank_accounts: 0
        cash_on_hand: 0
        stocks: 0
        bonds: 0
        other_financial_assets: 0
        vehicle_fair_market_value: 0
        receives_ssi: false
        receives_tanf: false
        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 775

    - name: "Family of 4 - moderate income"
      period: 2024-01
      inputs:
        household_size: 4
        gross_income: 2_200
        earned_income: 2_000
        shelter_costs: 1_100
        has_elderly_disabled: false
        bank_accounts: 500
        cash_on_hand: 0
        stocks: 0
        bonds: 0
        other_financial_assets: 0
        vehicle_fair_market_value: 0
        receives_ssi: false
        receives_tanf: false
        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 545

    - name: "Family of 4 - at 130% FPL threshold"
      period: 2024-01
      inputs:
        household_size: 4
        gross_income: 3_347
        earned_income: 3_000
        shelter_costs: 1_200
        has_elderly_disabled: false
        bank_accounts: 0
        cash_on_hand: 0
        stocks: 0
        bonds: 0
        other_financial_assets: 0
        vehicle_fair_market_value: 0
        receives_ssi: false
        receives_tanf: false
        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 0

    # ============================================================
    # Benefit Calculation Tests - Large Households
    # ============================================================
    - name: "Six person - zero income - maximum benefit"
      period: 2024-01
      inputs:
        household_size: 6
        gross_income: 0
        earned_income: 0
        shelter_costs: 0
        has_elderly_disabled: false
        bank_accounts: 0
        cash_on_hand: 0
        stocks: 0
        bonds: 0
