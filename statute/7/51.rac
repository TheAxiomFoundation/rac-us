        vehicle_fair_market_value: 0
        receives_ssi: false
        receives_tanf: false
        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 0

    # ============================================================
    # Deduction Impact Tests
    # ============================================================
    - name: "Shelter deduction reduces net income significantly"
      period: 2024-01
      inputs:
        household_size: 3
        gross_income: 1_800
        earned_income: 1_500
        shelter_costs: 1_200
        has_elderly_disabled: false
