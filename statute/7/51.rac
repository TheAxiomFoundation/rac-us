        medical_expenses: 0
      expect: 568

    - name: "Elderly/disabled uncapped shelter deduction"
      period: 2024-01
      inputs:
        household_size: 2
        gross_income: 1_500
        earned_income: 0
        shelter_costs: 2_000
        has_elderly_disabled: true
        bank_accounts: 0
        cash_on_hand: 0
        stocks: 0
        bonds: 0
        other_financial_assets: 0
        vehicle_fair_market_value: 0
        receives_ssi: false
        receives_tanf: false
        receives_general_assistance: false
        dependent_care_expenses: 0
        child_support_paid: 0
        medical_expenses: 0
      expect: 536

    - name: "Non-elderly/disabled capped shelter deduction"
      period: 2024-01
      inputs:
        household_size: 2
        gross_income: 1_500
        earned_income: 1_200
        shelter_costs: 2_000
        has_elderly_disabled: false
        bank_accounts: 0
