# 7 USC § 2014(e)(4) - Child Support Deduction
#
# "(4) legally obligated and actually paid child support payments"
#
# Deduction for child support payments made by a household member
# to a child not living in the household.

entity Household
period Month
dtype Money

formula:
  # § 2014(e)(4): Legally obligated child support payments actually made
  return child_support_paid
