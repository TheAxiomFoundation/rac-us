# 7 USC § 2014(g) - Allowable Financial Resources
#
# "(1) The Secretary shall prescribe the types and allowable amounts of financial
#  resources (liquid and nonliquid assets) an eligible household may own..."
# "(1)(B) ...increased for households with elderly or disabled members"
#
# Countable resources include: cash, bank accounts, stocks, bonds.
# Excludes: home, household goods, one vehicle (up to fair market value limit),
# retirement accounts, and certain income-producing property.

references {
  resource_limit: statute/7/2014/g/resource_limit
  resource_limit_elderly_disabled: statute/7/2014/g/resource_limit_elderly_disabled
}

variable snap_resource_eligible {
  entity Household
  period Month
  dtype Boolean

  formula {
    # § 2014(g)(1)(B): Higher limit for elderly/disabled households
    let limit = has_elderly_disabled
      ? resource_limit_elderly_disabled
      : resource_limit

    return countable_resources <= limit
  }
}

# Helper variable to calculate countable resources
# Excludes: home, household goods, one vehicle (up to FMV limit),
# retirement accounts, and certain other exempt resources
variable snap_countable_resources {
  entity Household
  period Month
  dtype Money

  formula {
    # Start with total liquid assets
    let liquid = bank_accounts + cash_on_hand

    # Add non-exempt financial assets
    let financial = stocks + bonds + other_financial_assets

    # Vehicle equity above exclusion (if applicable)
    # Per § 2014(g)(2)(B), one vehicle is excluded up to fair market value limit
    let vehicle_excess = max(0, vehicle_fair_market_value - vehicle_fair_market_value_exclusion)

    return liquid + financial + vehicle_excess
  }
}
