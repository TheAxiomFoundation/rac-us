- name: earned_income_deduction_uses_twenty_percent_rate
  period: 2026-10
  input:
    snap_earned_income_before_exclusions: 1000
  output:
    snap_earned_income_deduction: 200

- name: earned_income_exclusions_and_public_assistance_reduce_earned_income_for_deduction
  period: 2026-10
  input:
    snap_earned_income_before_exclusions: 1000
    snap_child_earned_income_exclusion: 100
    snap_other_earned_income_exclusions: 50
    snap_work_support_public_assistance_income: 150
  output:
    snap_earned_income: 700

- name: dependent_care_deduction_subtracts_excluded_expenses
  period: 2026-10
  input:
    snap_dependent_care_actual_costs: 80
    snap_dependent_care_excluded_expenses: 30
  output:
    snap_dependent_care_deduction: 50

- name: excess_medical_expense_deduction_applies_threshold_for_elderly_or_disabled_household
  period: 2026-10
  input:
    snap_household_has_elderly_or_disabled_member: true
    snap_allowable_medical_expenses_before_threshold: 45
  output:
    snap_excess_medical_expense_deduction: 10

- name: excess_medical_expense_deduction_is_zero_without_elderly_or_disabled_member
  period: 2026-10
  input:
    snap_household_has_elderly_or_disabled_member: false
    snap_allowable_medical_expenses_before_threshold: 100
  output:
    snap_excess_medical_expense_deduction: 0

- name: shelter_deduction_uses_homeless_deduction_when_household_claims_it
  period: 2026-10
  input:
    snap_claims_homeless_shelter_deduction: true
    snap_homeless_shelter_deduction: 198.99
    snap_monthly_shelter_cost: 900
    snap_excess_shelter_deduction_cap: 744
    snap_non_self_employment_income: 1500
  output:
    snap_shelter_deduction: 198.99

- name: excess_shelter_deduction_uses_threshold_formula_when_household_does_not_claim_homeless_deduction
  period: 2026-10
  input:
    snap_claims_homeless_shelter_deduction: false
    snap_non_self_employment_income: 1500
    snap_standard_deduction: 223
    snap_earned_income_before_exclusions: 1000
    snap_dependent_care_actual_costs: 80
    snap_dependent_care_excluded_expenses: 30
    snap_child_support_payments_made: 25
    snap_state_uses_child_support_deduction: true
    snap_household_has_elderly_or_disabled_member: true
    snap_allowable_medical_expenses_before_threshold: 45
    snap_monthly_shelter_cost: 596
    snap_excess_shelter_deduction_cap: 744
  output:
    snap_excess_shelter_expense_deduction: 100

- name: excess_shelter_deduction_is_capped_for_household_without_elderly_or_disabled_member
  period: 2026-10
  input:
    snap_non_self_employment_income: 2000
    snap_standard_deduction: 223
    snap_earned_income_before_exclusions: 1000
    snap_monthly_shelter_cost: 1700
    snap_excess_shelter_deduction_cap: 744
    snap_household_has_elderly_or_disabled_member: false
  output:
    snap_excess_shelter_expense_deduction: 744

- name: excess_shelter_deduction_is_uncapped_for_household_with_elderly_or_disabled_member
  period: 2026-10
  input:
    snap_non_self_employment_income: 2000
    snap_standard_deduction: 223
    snap_earned_income_before_exclusions: 1000
    snap_monthly_shelter_cost: 1700
    snap_excess_shelter_deduction_cap: 744
    snap_household_has_elderly_or_disabled_member: true
  output:
    snap_excess_shelter_expense_deduction: 911.5

- name: child_support_deduction_turns_on_when_state_elects_deduction
  period: 2026-10
  input:
    snap_child_support_payments_made: 300
    snap_state_uses_child_support_deduction: true
  output:
    snap_child_support_deduction: 300

- name: total_deductions_sum_all_active_components
  period: 2026-10
  input:
    snap_non_self_employment_income: 1500
    snap_standard_deduction: 223
    snap_earned_income_before_exclusions: 1000
    snap_dependent_care_actual_costs: 80
    snap_dependent_care_excluded_expenses: 30
    snap_child_support_payments_made: 25
    snap_state_uses_child_support_deduction: true
    snap_household_has_elderly_or_disabled_member: true
    snap_allowable_medical_expenses_before_threshold: 45
    snap_claims_homeless_shelter_deduction: false
    snap_monthly_shelter_cost: 596
    snap_excess_shelter_deduction_cap: 744
  output:
    snap_deductions: 608

- name: net_income_is_gross_income_minus_total_deductions_but_not_below_zero
  period: 2026-10
  input:
    snap_non_self_employment_income: 300
    snap_standard_deduction: 223
    snap_earned_income_before_exclusions: 1000
    snap_dependent_care_actual_costs: 80
    snap_dependent_care_excluded_expenses: 30
    snap_child_support_payments_made: 25
    snap_state_uses_child_support_deduction: true
    snap_household_has_elderly_or_disabled_member: true
    snap_allowable_medical_expenses_before_threshold: 45
    snap_claims_homeless_shelter_deduction: false
    snap_monthly_shelter_cost: 596
    snap_excess_shelter_deduction_cap: 744
  output:
    snap_net_income: 0
