snap_initial_month_proration_ratio:
    - name: "Initial-month proration ratio uses remaining days over total days"
      period: 2026-10
      inputs:
        snap_is_initial_month: true
        snap_initial_month_days_remaining: 16
        snap_initial_month_total_days: 31
      expect: 0.5161290322580645

snap_allotment_for_issuance_month:
    - name: "Initial month allotment is prorated from the full-month allotment"
      period: 2026-10
      inputs:
        snap_is_initial_month: true
        snap_initial_month_days_remaining: 16
        snap_initial_month_total_days: 31
        snap_household_size: 4
        snap_maximum_allotment: 994
        snap_one_person_thrifty_food_plan_cost: 298
      expect: 513

    - name: "Initial month allotment below ten dollars is not issued"
      period: 2026-10
      inputs:
        snap_is_initial_month: true
        snap_initial_month_days_remaining: 5
        snap_initial_month_total_days: 31
        snap_household_size: 1
        snap_maximum_allotment: 50
        snap_one_person_thrifty_food_plan_cost: 298
      expect: 0

    - name: "Non-initial month uses the full monthly allotment"
      period: 2026-10
      inputs:
        snap_is_initial_month: false
        snap_household_size: 4
        snap_maximum_allotment: 994
        snap_one_person_thrifty_food_plan_cost: 298
      expect: 994

    - name: "Initial month issuance is zero when the household is not federally eligible"
      period: 2026-10
      inputs:
        snap_is_initial_month: true
        snap_initial_month_days_remaining: 31
        snap_initial_month_total_days: 31
        snap_household_size: 4
        snap_maximum_allotment: 994
        snap_one_person_thrifty_food_plan_cost: 298
        snap_net_income_limit: 2680
        snap_gross_income_limit: 3483
        snap_asset_limit: 3000
        snap_asset_limit_with_elderly_or_disabled_member: 4500
        snap_total_resources_before_exclusions: 3001
      expect: 0
