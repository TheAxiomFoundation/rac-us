# 26 USC Section 21(d)(2) tests

deemed_earned_income_one_qualifying_amount:
    - name: "Monthly deemed earned income is $250 with one qualifying individual"
      period: 2024-01
      inputs:
        deemed_earned_income_one_qualifying_from_a: 250
      expect: 250

deemed_earned_income_two_or_more_qualifying_amount:
    - name: "Monthly deemed earned income is $500 with two or more qualifying individuals"
      period: 2024-01
      inputs:
        deemed_earned_income_two_or_more_qualifying_from_b: 500
      expect: 500
