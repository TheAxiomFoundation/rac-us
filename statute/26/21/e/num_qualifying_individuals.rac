# 26 USC 21(b) - Number of Qualifying Individuals
#
variable num_qualifying_individuals:
  imports: [26/21/e/is_qualifying_individual#is_cdcc_qualifying_individual]
  entity: TaxUnit
  period: Year
  dtype: Count
  label: "Number of CDCC Qualifying Individuals"
  description: "Count of qualifying individuals for Child and Dependent Care Credit per 26 USC 21(b)"
  formula: return tax_unit.members.count(is_cdcc_qualifying_individual)
