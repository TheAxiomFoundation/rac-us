# 26 USC Section 21 tests

section_21_credit:
    - name: "Passes through imported child and dependent care credit amount"
      period: 2024-01
      inputs:
        child_and_dependent_care_credit: 600
      expect: 600

    - name: "Zero imported credit remains zero"
      period: 2024-01
      inputs:
        child_and_dependent_care_credit: 0
      expect: 0
