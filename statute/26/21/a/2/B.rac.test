# 26 USC Section 21(a)(2)(B) tests

further_reduction:
    - name: "AGI below threshold (single) - no further reduction"
      period: 2024-01
      inputs:
        adjusted_gross_income: 70000
        is_joint_return: false
      expect: 0

    - name: "AGI at threshold (single) - no further reduction"
      period: 2024-01
      inputs:
        adjusted_gross_income: 75000
        is_joint_return: false
      expect: 0

    - name: "AGI $1 over threshold (single) - 1 increment due to fraction"
      period: 2024-01
      inputs:
        adjusted_gross_income: 75001
        is_joint_return: false
      expect: 0.01

    - name: "AGI $5,000 over threshold (single) - 3 increments (ceil(5000/2000)=3)"
      period: 2024-01
      inputs:
        adjusted_gross_income: 80000
        is_joint_return: false
      expect: 0.03

    - name: "Joint return uses higher threshold and increment"
      period: 2024-01
      inputs:
        adjusted_gross_income: 158000
        is_joint_return: true
      expect: 0.02
