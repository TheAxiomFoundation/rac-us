# 26 USC Section 21(c)(2) - Dollar limit for 2 or more qualifying individuals

"""
(2) $6,000 if there are 2 or more qualifying individuals with respect to
the taxpayer for such taxable year.
"""

status: encoded

expense_limit_two_or_more_qualifying_individuals:
