# 26 USC § 164(a) - Deduction for Taxes
#

text: """
There shall be allowed as a deduction taxes paid or accrued within the
taxable year...
"""
variable deductible_taxes:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: "USD"
  label: "Local Benefit Assessments"
  description: "Special assessments for streets, sidewalks, etc. - NOT deductible under § 164(a)(5)"
  formula: |
    # Total real property minus foreign portion
    real_property_tax - foreign_real_property_tax
  default: false
