# 26 USC § 25A - Education Credits (Validation Version)
#
# Standalone encoding for validation against PolicyEngine and other calculators.
# Uses pre-computed inputs (num_aoc_students, qualified_expenses, filing_status, etc.)
# and applies the § 25A formula to compute the credit amounts.
#
# 2024 parameters:
# - AOC: $2,500 max per student, 40% refundable ($1,000 max refundable)
# - LLC: $2,000 max per return, not refundable
# - AOC phase-out: $80k-$90k single, $160k-$180k joint (not indexed)
# - LLC phase-out: $80k-$90k single, $160k-$180k joint (indexed)

imports:
# AOC parameters
  aoc_first_tier_limit: statute/26/25A/b/aoc_parameters#aoc_first_tier_limit
  aoc_second_tier_limit: statute/26/25A/b/aoc_parameters#aoc_second_tier_limit
  aoc_first_tier_rate: statute/26/25A/b/aoc_parameters#aoc_first_tier_rate
  aoc_second_tier_rate: statute/26/25A/b/aoc_parameters#aoc_second_tier_rate
  aoc_refundable_rate: statute/26/25A/i/refundable_parameters#aoc_refundable_rate

# LLC parameters
  llc_expense_limit: statute/26/25A/c/llc_parameters#llc_expense_limit
  llc_rate: statute/26/25A/c/llc_parameters#llc_rate

# Phaseout parameters
  aoc_phaseout_start_single: statute/26/25A/d/phaseout_parameters#aoc_phaseout_start_single
  aoc_phaseout_start_joint: statute/26/25A/d/phaseout_parameters#aoc_phaseout_start_joint
  aoc_phaseout_range_single: statute/26/25A/d/phaseout_parameters#aoc_phaseout_range_single
  aoc_phaseout_range_joint: statute/26/25A/d/phaseout_parameters#aoc_phaseout_range_joint
  llc_phaseout_start_single: statute/26/25A/d/phaseout_parameters#llc_phaseout_start_single
  llc_phaseout_start_joint: statute/26/25A/d/phaseout_parameters#llc_phaseout_start_joint
  llc_phaseout_range_single: statute/26/25A/d/phaseout_parameters#llc_phaseout_range_single
  llc_phaseout_range_joint: statute/26/25A/d/phaseout_parameters#llc_phaseout_range_joint

# Filing status values per Section 1
enum FilingStatus {
SINGLE
JOINT
SEPARATE
HEAD_OF_HOUSEHOLD
SURVIVING_SPOUSE

# =============================================================================
# AMERICAN OPPORTUNITY CREDIT (AOC)
# =============================================================================

# --- Per-Student Calculation ---

entity Person
period Year
dtype Money
unit "USD"
label "AOC Per Student"
description "American Opportunity Credit for a single student per § 25A(b)(1)"

formula:
  # 100% of first $2,000 + 25% of next $2,000 = max $2,500
  expenses = aoc_qualified_expenses

  first_tier = min(expenses, aoc_first_tier_limit) * aoc_first_tier_rate
  second_tier_expenses = max(0, min(expenses, aoc_second_tier_limit) - aoc_first_tier_limit)
  second_tier = second_tier_expenses * aoc_second_tier_rate

  return first_tier + second_tier

# --- Phaseout ---

entity TaxUnit
period Year
dtype Money
unit "USD"
label "AOC Phaseout Start"
description "MAGI where AOC phaseout begins per § 25A(d)(2)(B)(i)"

formula:
  return match filing_status {
  case JOINT => aoc_phaseout_start_joint
  case SURVIVING_SPOUSE => aoc_phaseout_start_joint
  else => aoc_phaseout_start_single

entity TaxUnit
period Year
dtype Money
unit "USD"
label "AOC Phaseout Range"
description "MAGI range over which AOC phases out per § 25A(d)(2)(B)(ii)"

formula:
  return match filing_status {
  case JOINT => aoc_phaseout_range_joint
  case SURVIVING_SPOUSE => aoc_phaseout_range_joint
  else => aoc_phaseout_range_single

entity TaxUnit
period Year
dtype Rate
unit "rate"
label "AOC Phaseout Ratio"
description "Reduction ratio for AOC based on MAGI"

formula:
  magi = modified_adjusted_gross_income
  threshold = aoc_phaseout_threshold
  range = aoc_phaseout_range

  if magi <= threshold then
  return 0

  excess = magi - threshold
  return min(1.0, excess / range)

# --- Total AOC ---

entity TaxUnit
period Year
dtype Money
unit "USD"
label "AOC Before Phaseout"
description "Total AOC for all students before phaseout"

formula:
  # Sum credits for all AOC-eligible students
  return sum(members.aoc_credit_per_student where members.is_aoc_eligible_student)

entity TaxUnit
period Year
dtype Money
unit "USD"
label "American Opportunity Credit"
description "AOC after phaseout per 26 USC § 25A(b)"

formula:
  before = aoc_before_phaseout
  ratio = aoc_phaseout_ratio

  return before * (1 - ratio)

entity TaxUnit
period Year
dtype Money
unit "USD"
label "Refundable AOC"
description "40% refundable portion of AOC per § 25A(i)(1)"

formula:
  return american_opportunity_credit * aoc_refundable_rate

entity TaxUnit
period Year
dtype Money
unit "USD"
label "Nonrefundable AOC"
description "60% nonrefundable portion of AOC"

formula:
  total = american_opportunity_credit
  refundable = aoc_refundable_amount

  # Nonrefundable portion is limited by tax liability
  nonref = total - refundable
  return min(nonref, tax_liability_before_credits)

# =============================================================================
# LIFETIME LEARNING CREDIT (LLC)
# =============================================================================

entity TaxUnit
period Year
dtype Money
unit "USD"
label "LLC Qualified Expenses"
description "Total qualified expenses for LLC (excluding AOC students)"

formula:
  # Sum expenses for students NOT claiming AOC (can't claim both for same student)
  return sum(members.llc_qualified_expenses where not members.is_aoc_eligible_student)

entity TaxUnit
period Year
dtype Money
unit "USD"
label "LLC Before Phaseout"
description "Lifetime Learning Credit before phaseout per § 25A(c)(1)"

formula:
  # 20% of expenses up to $10,000
  eligible = min(llc_qualified_expenses_total, llc_expense_limit)
  return eligible * llc_rate

# --- LLC Phaseout ---

entity TaxUnit
period Year
dtype Money
unit "USD"
label "LLC Phaseout Start"
description "MAGI where LLC phaseout begins per § 25A(d)(2)(B)(i)"

formula:
  return match filing_status {
  case JOINT => llc_phaseout_start_joint
  case SURVIVING_SPOUSE => llc_phaseout_start_joint
  else => llc_phaseout_start_single

entity TaxUnit
period Year
dtype Money
unit "USD"
label "LLC Phaseout Range"
description "MAGI range over which LLC phases out per § 25A(d)(2)(B)(ii)"

formula:
  return match filing_status {
  case JOINT => llc_phaseout_range_joint
  case SURVIVING_SPOUSE => llc_phaseout_range_joint
  else => llc_phaseout_range_single

entity TaxUnit
period Year
dtype Rate
unit "rate"
label "LLC Phaseout Ratio"
description "Reduction ratio for LLC based on MAGI"

formula:
  magi = modified_adjusted_gross_income
  threshold = llc_phaseout_threshold
  range = llc_phaseout_range

  if magi <= threshold then
  return 0

  excess = magi - threshold
  return min(1.0, excess / range)

entity TaxUnit
period Year
dtype Money
unit "USD"
label "Lifetime Learning Credit"
description "LLC after phaseout per 26 USC § 25A(c)"

formula:
  before = llc_before_phaseout
  ratio = llc_phaseout_ratio

  return before * (1 - ratio)

# =============================================================================
# COMBINED EDUCATION CREDITS
# =============================================================================

entity TaxUnit
period Year
dtype Money
unit "USD"
label "Total Education Credits"
description "Combined AOC and LLC per § 25A(a)"

formula:
  return american_opportunity_credit + lifetime_learning_credit

entity TaxUnit
period Year
dtype Money
unit "USD"
label "Nonrefundable Education Credit"
description "Nonrefundable portion (60% AOC + 100% LLC) limited by tax liability"

formula:
  aoc_nonref = aoc_nonrefundable_amount
  llc = lifetime_learning_credit

  # LLC is entirely nonrefundable, limited by remaining tax liability
  remaining_liability = max(0, tax_liability_before_credits - aoc_nonref)
  llc_allowed = min(llc, remaining_liability)

  return aoc_nonref + llc_allowed

entity TaxUnit
period Year
dtype Money
unit "USD"
label "Refundable Education Credit"
description "Refundable portion (40% of AOC per § 25A(i))"

formula:
  return aoc_refundable_amount

entity TaxUnit
period Year
dtype Money
unit "USD"
label "Education Credit"
description "Total education credit claimed per 26 USC § 25A"

formula:
  return education_credit_nonrefundable + education_credit_refundable
