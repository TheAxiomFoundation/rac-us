parameter joint_adjustment:
  description: "Additional phaseout threshold amount for joint filers"
  reference: "26 USC 32(b)(2)(B); Rev. Proc. 2017-58, Rev. Proc. 2018-57, Rev. Proc. 2019-44, Rev. Proc. 2020-45, Rev. Proc. 2021-45, Rev. Proc. 2022-38, Rev. Proc. 2023-34"
