        earned_income_cap_1: 12_390
        earned_income_cap_2: 17_400
        phaseout_rate_0: 0.765
        phaseout_rate_1: 0.1_598
        phaseout_rate_2: 0.2_106
        phaseout_start_0: 10_330
        phaseout_start_1: 22_720
        joint_adjustment: 6_920
      expect: 2305.944  # Same as SINGLE (no adjustment for HOH), Reduction: 0.1598 * (35000 - 22720) = 1961.136; Credit: 4212.6 - 1961.136 = 2251.464

    # ============================================================================
    # ZERO AND ABOVE PHASE-OUT TESTS
    # ============================================================================
    - name: "Single, no children, zero earned income"
      period: 2024-01
      inputs:
        num_qualifying_children: 0
        earned_income: 0
        adjusted_gross_income: 0
        filing_status: SINGLE
        is_eligible_individual: true
        credit_rate_0: 0.765
        credit_rate_1: 0.34
        credit_rate_2: 0.40
        credit_rate_3: 0.45
        earned_income_cap_0: 8_260
        earned_income_cap_1: 12_390
        earned_income_cap_2: 17_400
        phaseout_rate_0: 0.765
        phaseout_rate_1: 0.1_598
        phaseout_rate_2: 0.2_106
        phaseout_start_0: 10_330
        phaseout_start_1: 22_720
        joint_adjustment: 6_920
      expect: 0

    - name: "Single, 1 child, completely phased out: $50_000"
      period: 2024-01
      inputs:
        num_qualifying_children: 1
        earned_income: 50_000
        adjusted_gross_income: 50_000
        filing_status: SINGLE
        is_eligible_individual: true
        credit_rate_0: 0.765
        credit_rate_1: 0.34
        credit_rate_2: 0.40
        credit_rate_3: 0.45
        earned_income_cap_0: 8_260
        earned_income_cap_1: 12_390
        earned_income_cap_2: 17_400
        phaseout_rate_0: 0.765
        phaseout_rate_1: 0.1_598
        phaseout_rate_2: 0.2_106
        phaseout_start_0: 10_330
        phaseout_start_1: 22_720
        joint_adjustment: 6_920
      expect: 0  # Phaseout threshold + ~26,368 / 0.1598 = 165k so not fully phased out; max(0, 4212.6 - 0.1598*(50000-22720)) = 4212.6 - 4368.6 = 0

    - name: "Single, no children, completely phased out: $20_000"
      period: 2024-01
      inputs:
        num_qualifying_children: 0
        earned_income: 20_000
        adjusted_gross_income: 20_000
        filing_status: SINGLE
        is_eligible_individual: true
        credit_rate_0: 0.765
        credit_rate_1: 0.34
        credit_rate_2: 0.40
        credit_rate_3: 0.45
        earned_income_cap_0: 8_260
        earned_income_cap_1: 12_390
        earned_income_cap_2: 17_400
        phaseout_rate_0: 0.765
        phaseout_rate_1: 0.1_598
        phaseout_rate_2: 0.2_106
        phaseout_start_0: 10_330
        phaseout_start_1: 22_720
        joint_adjustment: 6_920
      expect: 0  # Max 632; Reduction: 0.0765 * (20000 - 10330) = 738.655; Credit: max(0, 632 - 738.655) = 0

    # ============================================================================
    # INVESTMENT INCOME LIMIT TESTS
    # ============================================================================
    - name: "Single, 1 child, just below investment income limit: $11_599"
      period: 2024-01
      inputs:
        num_qualifying_children: 1
        earned_income: 12_390
        adjusted_gross_income: 12_390
        filing_status: SINGLE
        is_eligible_individual: true
        credit_rate_0: 0.765
        credit_rate_1: 0.34
        credit_rate_2: 0.40
        credit_rate_3: 0.45
        earned_income_cap_0: 8_260
        earned_income_cap_1: 12_390
        earned_income_cap_2: 17_400
        phaseout_rate_0: 0.765
        phaseout_rate_1: 0.1_598
