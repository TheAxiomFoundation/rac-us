parameter phaseout_start_1:
  description: "EITC phaseout start for taxpayers with qualifying children"
  reference: "26 USC 32(b)(2)(A); Rev. Proc. 2017-58, Rev. Proc. 2018-57, Rev. Proc. 2019-44, Rev. Proc. 2020-45, Rev. Proc. 2021-45, Rev. Proc. 2022-38, Rev. Proc. 2023-34"
