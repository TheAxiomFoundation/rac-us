        joint_adjustment: 6_920
      expect: 4212.6  # 0.34 * 12390 = 4212.6 (at cap, no phaseout yet)

    - name: "Joint, 2 children, $30_000 earned income"
      period: 2024-01
      inputs:
        num_qualifying_children: 2
        earned_income: 30_000
        adjusted_gross_income: 30_000
        filing_status: JOINT
        is_eligible_individual: true
        credit_rate_0: 0.765
        credit_rate_1: 0.34
        credit_rate_2: 0.40
        credit_rate_3: 0.45
        earned_income_cap_0: 8_260
        earned_income_cap_1: 12_390
        earned_income_cap_2: 17_400
