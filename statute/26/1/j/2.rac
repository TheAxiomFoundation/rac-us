# === INPUTS ===

input taxable_income:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Taxable Income"
  description: "Taxable income per 26 USC 63"
  default: 0

input filing_status:
  entity: TaxUnit
  period: Year
  dtype: Enum[FilingStatus]
  label: "Filing Status"
  description: "Tax filing status determining applicable bracket thresholds"
  default: SINGLE

# === HELPER VARIABLES ===
# Select thresholds based on filing status using ternary expressions

variable t1:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Threshold 1"
  description: "End of 10% bracket for filing status"
  formula: |
    if filing_status == SINGLE: threshold_single_1 elif filing_status == JOINT: threshold_joint_1 elif filing_status == SURVIVING_SPOUSE: threshold_joint_1 elif filing_status == SEPARATE: threshold_separate_1 else threshold_hoh_1
  default: 0

variable t2:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Threshold 2"
  description: "End of 12% bracket for filing status"
  formula: |
    if filing_status == SINGLE: threshold_single_2 elif filing_status == JOINT: threshold_joint_2 elif filing_status == SURVIVING_SPOUSE: threshold_joint_2 elif filing_status == SEPARATE: threshold_separate_2 else threshold_hoh_2
  default: 0

variable t3:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Threshold 3"
  description: "End of 22% bracket for filing status"
  formula: |
    if filing_status == SINGLE: threshold_single_3 elif filing_status == JOINT: threshold_joint_3 elif filing_status == SURVIVING_SPOUSE: threshold_joint_3 elif filing_status == SEPARATE: threshold_separate_3 else threshold_hoh_3
  default: 0

variable t4:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Threshold 4"
  description: "End of 24% bracket for filing status"
  formula: |
    if filing_status == SINGLE: threshold_single_4 elif filing_status == JOINT: threshold_joint_4 elif filing_status == SURVIVING_SPOUSE: threshold_joint_4 elif filing_status == SEPARATE: threshold_separate_4 else threshold_hoh_4
  default: 0

variable t5:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Threshold 5"
  description: "End of 32% bracket for filing status"
  formula: |
    if filing_status == SINGLE: threshold_single_5 elif filing_status == JOINT: threshold_joint_5 elif filing_status == SURVIVING_SPOUSE: threshold_joint_5 elif filing_status == SEPARATE: threshold_separate_5 else threshold_hoh_5
  default: 0

variable t6:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Threshold 6"
  description: "End of 35% bracket for filing status"
  formula: |
    if filing_status == SINGLE: threshold_single_6 elif filing_status == JOINT: threshold_joint_6 elif filing_status == SURVIVING_SPOUSE: threshold_joint_6 elif filing_status == SEPARATE: threshold_separate_6 else threshold_hoh_6
  default: 0

# === BRACKET TAX AMOUNTS ===
# Calculate tax for each bracket segment

variable tax_bracket_1:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Tax from Bracket 1"
  description: "Tax on income in 10% bracket"
  formula: |
    min(taxable_income, t1) * rate_1
  default: 0

variable tax_bracket_2:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Tax from Bracket 2"
  description: "Tax on income in 12% bracket"
  formula: |
    if taxable_income > t1: (min(taxable_income, t2) - t1) * rate_2 else 0
  default: 0

variable tax_bracket_3:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Tax from Bracket 3"
  description: "Tax on income in 22% bracket"
  formula: |
    if taxable_income > t2: (min(taxable_income, t3) - t2) * rate_3 else 0
  default: 0

variable tax_bracket_4:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Tax from Bracket 4"
  description: "Tax on income in 24% bracket"
  formula: |
    if taxable_income > t3: (min(taxable_income, t4) - t3) * rate_4 else 0
  default: 0

variable tax_bracket_5:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Tax from Bracket 5"
  description: "Tax on income in 32% bracket"
  formula: |
    if taxable_income > t4: (min(taxable_income, t5) - t4) * rate_5 else 0
  default: 0

variable tax_bracket_6:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Tax from Bracket 6"
  description: "Tax on income in 35% bracket"
  formula: |
    if taxable_income > t5: (min(taxable_income, t6) - t5) * rate_6 else 0
  default: 0

variable tax_bracket_7:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Tax from Bracket 7"
  description: "Tax on income in 37% bracket"
  formula: |
    if taxable_income > t6: (taxable_income - t6) * rate_7 else 0
  default: 0

# === MAIN VARIABLE ===

variable income_tax_before_credits:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Income Tax Before Credits"
  description: "Federal income tax from marginal brackets per 26 USC 1(j)(2)"
  formula: |
    if taxable_income <= 0: return 0
    return tax_bracket_1 + tax_bracket_2 + tax_bracket_3 + tax_bracket_4 + tax_bracket_5 + tax_bracket_6 + tax_bracket_7
  default: 0
  tests:
    - name: "Single filer, $50k taxable income"
      period: 2018-01
      inputs:
        taxable_income: 50000
        filing_status: SINGLE
        t1: 9525
        t2: 38700
        t3: 82500
        t4: 157500
        t5: 200000
        t6: 500000
        tax_bracket_1: 952.50
        tax_bracket_2: 3501
        tax_bracket_3: 2486
        tax_bracket_4: 0
        tax_bracket_5: 0
        tax_bracket_6: 0
        tax_bracket_7: 0
      expect: 6939.50
    - name: "Joint filers, $100k taxable income"
      period: 2018-01
      inputs:
        taxable_income: 100000
        filing_status: JOINT
        t1: 19050
        t2: 77400
        t3: 165000
        t4: 315000
        t5: 400000
        t6: 600000
        tax_bracket_1: 1905
        tax_bracket_2: 7002
        tax_bracket_3: 4972
        tax_bracket_4: 0
        tax_bracket_5: 0
        tax_bracket_6: 0
        tax_bracket_7: 0
      expect: 13879
    - name: "Head of household, $75k taxable income"
      period: 2018-01
      inputs:
        taxable_income: 75000
        filing_status: HEAD_OF_HOUSEHOLD
        t1: 13600
        t2: 51800
        t3: 82500
        t4: 157500
        t5: 200000
        t6: 500000
        tax_bracket_1: 1360
        tax_bracket_2: 4584
        tax_bracket_3: 5104
        tax_bracket_4: 0
        tax_bracket_5: 0
        tax_bracket_6: 0
        tax_bracket_7: 0
      expect: 11048
    - name: "Zero income"
      period: 2018-01
      inputs:
        taxable_income: 0
        filing_status: SINGLE
        t1: 9525
        t2: 38700
        t3: 82500
        t4: 157500
        t5: 200000
        t6: 500000
        tax_bracket_1: 0
        tax_bracket_2: 0
        tax_bracket_3: 0
        tax_bracket_4: 0
        tax_bracket_5: 0
        tax_bracket_6: 0
        tax_bracket_7: 0
      expect: 0
