    2018-01-01: 9525

parameter threshold_separate_2:
  description: "MFS: end of 12% bracket"
  unit: USD
  indexed_by: statute/26/1/f
  values:
    2018-01-01: 38700

parameter threshold_separate_3:
  description: "MFS: end of 22% bracket"
