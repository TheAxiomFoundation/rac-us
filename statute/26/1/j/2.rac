  description: "Single: end of 22% bracket"
  unit: USD
  indexed_by: statute/26/1/f
  values:
    2018-01-01: 82500

parameter threshold_single_4:
  description: "Single: end of 24% bracket"
  unit: USD
  indexed_by: statute/26/1/f
  values:
    2018-01-01: 157500

parameter threshold_single_5:
  description: "Single: end of 32% bracket"
  unit: USD
  indexed_by: statute/26/1/f
  values:
    2018-01-01: 200000

parameter threshold_single_6:
  description: "Single: end of 35% bracket"
  unit: USD
  indexed_by: statute/26/1/f
  values:
    2018-01-01: 500000

