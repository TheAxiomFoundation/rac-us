# 26 USC 24(d)(2)(B) tests

social_security_taxes_after_special_refund:
    - name: "No special refund - full SS taxes retained"
      period: 2024-01
      inputs:
        social_security_taxes: 8000
        special_refund_of_social_security_taxes: 0
      expect: 8000

    - name: "Partial special refund reduces SS taxes"
      period: 2024-01
      inputs:
        social_security_taxes: 8000
        special_refund_of_social_security_taxes: 2000
      expect: 6000

    - name: "Special refund equals SS taxes - zero result"
      period: 2024-01
      inputs:
        social_security_taxes: 5000
        special_refund_of_social_security_taxes: 5000
      expect: 0

    - name: "Special refund exceeds SS taxes - floored at zero"
      period: 2024-01
      inputs:
        social_security_taxes: 3000
        special_refund_of_social_security_taxes: 4000
      expect: 0

    - name: "Zero SS taxes with zero refund"
      period: 2024-01
      inputs:
        social_security_taxes: 0
        special_refund_of_social_security_taxes: 0
      expect: 0
