# 26 USC 24(d)(2)(C) tests

foreign_affiliate_agreement_taxes:
    - name: "No agreement amounts - just social security taxes"
      period: 2024-01
      inputs:
        social_security_taxes: 5000
        section_3121l_agreement_amounts: 0
      expect: 5000

    - name: "Agreement amounts added to social security taxes"
      period: 2024-01
      inputs:
        social_security_taxes: 5000
        section_3121l_agreement_amounts: 2000
      expect: 7000

    - name: "Only agreement amounts, no other social security taxes"
      period: 2024-01
      inputs:
        social_security_taxes: 0
        section_3121l_agreement_amounts: 3500
      expect: 3500

    - name: "Zero values"
      period: 2024-01
      inputs:
        social_security_taxes: 0
        section_3121l_agreement_amounts: 0
      expect: 0
