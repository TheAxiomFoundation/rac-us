# 26 USC Section 24(d)(1)(A) tests

ctc_without_limitations:
    - name: "Two qualifying children, no phaseout"
      period: 2024-01
      inputs:
          ctc_allowance: 4000
          ctc_phaseout_reduction: 0
      expect: 4000

    - name: "Partial phaseout reduces credit"
      period: 2024-01
      inputs:
          ctc_allowance: 4000
          ctc_phaseout_reduction: 1500
      expect: 2500

    - name: "Full phaseout eliminates credit"
      period: 2024-01
      inputs:
          ctc_allowance: 2000
          ctc_phaseout_reduction: 3000
      expect: 0

    - name: "Zero allowance"
      period: 2024-01
      inputs:
          ctc_allowance: 0
          ctc_phaseout_reduction: 0
      expect: 0

    - name: "Phaseout exactly equals allowance"
      period: 2024-01
      inputs:
          ctc_allowance: 2000
          ctc_phaseout_reduction: 2000
      expect: 0
