# 26 USC Section 24 - Child Tax Credit (Validation Version)
#
# Standalone encoding for validation against PolicyEngine and other calculators.
# Uses pre-computed inputs (num_qualifying_children, filing_status, etc.)
# and applies the Section 24 formula to compute the credit amount.
#
# Parameters sourced from:
# - statute/26/24/h/2/credit_amount.yaml - Credit per child
# - statute/26/24/h/4/other_dependent_amount.yaml - Credit per other dependent
# - statute/26/24/h/5/refundable_maximum.yaml - Refundable (ACTC) cap
# - statute/26/24/b/1/threshold.yaml - Phase-out thresholds
# - statute/26/24/b/2/phaseout_rate.yaml - Phase-out rate
# - statute/26/24/ctc_phaseout_increment.yaml - Phaseout increment
# - statute/26/24/d/1/B/parameters.yaml - Earned income threshold, refundable rate
# - statute/26/24/actc_qualifying_children_threshold.yaml - 3+ children threshold

imports:
  # Credit amounts from parameters
  ctc_credit_amount_param: statute/26/24/h/2/credit_amount#credit_amount
  ctc_other_dependent_amount_param: statute/26/24/h/4/other_dependent_amount#other_dependent_amount
  ctc_phaseout_threshold_joint_param: statute/26/24/b/1/threshold#phaseout_threshold_joint
  ctc_phaseout_threshold_single_param: statute/26/24/b/1/threshold#phaseout_threshold_single
  ctc_phaseout_rate_param: statute/26/24/b/2/phaseout_rate#phaseout_rate
  ctc_phaseout_increment_param: statute/26/24/ctc_phaseout_increment#phaseout_increment
  actc_refundable_maximum_param: statute/26/24/h/5/refundable_maximum#refundable_maximum
  actc_earned_income_threshold_param: statute/26/24/d/1/B/parameters#earned_income_threshold
  actc_refundable_rate_param: statute/26/24/d/1/B/parameters#refundable_rate
  qualifying_children_ss_threshold: statute/26/24/actc_qualifying_children_threshold#qualifying_children_ss_threshold

# Filing status enum per Section 1
enum FilingStatus:
  SINGLE
  JOINT
  SEPARATE
  HEAD_OF_HOUSEHOLD
  SURVIVING_SPOUSE

# === External Inputs (provided by simulation) ===

# 26 USC Section 24(c)
variable num_qualifying_children:
  entity TaxUnit
  period Year
  dtype Count
  label "Number of CTC Qualifying Children"
  description "Count of children qualifying for Child Tax Credit per Section 24(c)"
  default 0

# 26 USC Section 24(h)(4)
variable num_other_dependents:
  entity TaxUnit
  period Year
  dtype Count
  label "Number of Other Dependents"
  description "Count of other dependents qualifying for $500 credit per Section 24(h)(4)"
  default 0

# 26 USC Section 62
variable adjusted_gross_income:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "Adjusted Gross Income"
  description "AGI per Section 62"
  default 0

# Earned income for CTC calculation
variable earned_income:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "Earned Income"
  description "Earned income for ACTC calculation per Section 24(d)(1)(B)"
  default 0

# Tax liability before credits
variable tax_liability_before_credits:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "Tax Liability Before Credits"
  description "Income tax before nonrefundable credits per Section 26(a)"
  default 0

# Social security taxes
variable social_security_taxes:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "Social Security Taxes"
  description "Employee portion of FICA taxes for ACTC calculation"
  default 0

# EITC amount
variable earned_income_credit:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "Earned Income Credit"
  description "EITC amount for ACTC calculation with 3+ children"
  default 0

# Filing status
variable filing_status:
  entity TaxUnit
  period Year
  dtype Enum(FilingStatus)
  label "Filing Status"
  description "Federal income tax filing status per Section 1"
  default SINGLE

# === Parameter-backed Variables ===

# Credit per qualifying child (from parameters)
variable ctc_credit_amount:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "CTC Credit Amount Per Child"
  description "Credit amount per qualifying child per 26 USC 24(h)(2)"

  formula:
    return ctc_credit_amount_param

# Credit per other dependent (from parameters)
variable ctc_other_dependent_amount:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "Other Dependent Credit Amount"
  description "Credit amount per other dependent per 26 USC 24(h)(4)"

  formula:
    return ctc_other_dependent_amount_param

# Phase-out threshold for joint filers (from parameters)
variable ctc_phaseout_threshold_joint:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "CTC Phase-Out Threshold (Joint)"
  description "AGI threshold for joint filers per 26 USC 24(b)(1)(A)"

  formula:
    return ctc_phaseout_threshold_joint_param

# Phase-out threshold for other filers (from parameters)
variable ctc_phaseout_threshold_single:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "CTC Phase-Out Threshold (Single)"
  description "AGI threshold for non-joint filers per 26 USC 24(b)(1)(B)"

  formula:
    return ctc_phaseout_threshold_single_param

# Phase-out rate (from parameters)
variable ctc_phaseout_rate:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "CTC Phase-Out Rate"
  description "Credit reduction per $1,000 over threshold per 26 USC 24(b)(2)"

  formula:
    return ctc_phaseout_rate_param

# Maximum refundable per child (from parameters)
variable actc_refundable_maximum:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "ACTC Refundable Maximum Per Child"
  description "Maximum refundable amount per child per 26 USC 24(h)(5)"

  formula:
    return actc_refundable_maximum_param

# Earned income threshold (from parameters)
variable actc_earned_income_threshold:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "ACTC Earned Income Threshold"
  description "Earned income floor for refundable credit per 26 USC 24(d)(1)(B)(i)"

  formula:
    return actc_earned_income_threshold_param

# Refundable rate (from parameters)
variable actc_refundable_rate:
  entity TaxUnit
  period Year
  dtype Rate
  label "ACTC Refundable Rate"
  description "Percentage of earned income above threshold per 26 USC 24(d)(1)(B)(i)"

  formula:
    return actc_refundable_rate_param

# === Credit Calculations ===

# Phase-out threshold based on filing status
variable ctc_phaseout_threshold:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "CTC Phase-Out Threshold"
  description "Income threshold where phase-out begins per Section 24(b)(1)"

  formula:
    if filing_status == JOINT: return ctc_phaseout_threshold_joint
    if filing_status == SURVIVING_SPOUSE: return ctc_phaseout_threshold_joint
    return ctc_phaseout_threshold_single

# CTC before phase-out (maximum amount)
variable ctc_before_phaseout:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "CTC Before Phase-Out"
  description "Total credit for all qualifying children and other dependents before phase-out"

  formula:
    let child_credit = num_qualifying_children * ctc_credit_amount
    let other_credit = num_other_dependents * ctc_other_dependent_amount
    return child_credit + other_credit

# Phase-out reduction
variable ctc_phaseout_reduction:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "CTC Phase-Out Reduction"
  description "Credit reduction based on income exceeding threshold per Section 24(b)(2)"

  formula:
    let excess = adjusted_gross_income - ctc_phaseout_threshold
    if excess <= 0 : 0
    else ceil(excess / ctc_phaseout_increment_param) * ctc_phaseout_rate

# Total CTC (this IS the final credit per PolicyEngine's convention)
# In PolicyEngine, ctc = max(0, maximum - phase_out)
# The total is NOT limited by tax liability
variable total_child_tax_credit:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "Total Child Tax Credit"
  description "Total CTC per 26 USC Section 24 (sum of nonrefundable and refundable portions)"

  formula:
    return max(0, ctc_before_phaseout - ctc_phaseout_reduction)

# --- Additional variables for component analysis (optional) ---

# Phase-in amount (earned income formula)
variable ctc_phase_in_earnings:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "CTC Phase-In (Earned Income Formula)"
  description "15% of earned income exceeding $2,500 per Section 24(d)(1)(B)(i)"

  formula:
    let excess = max(0, earned_income - actc_earned_income_threshold)
    return actc_refundable_rate * excess

# Social security excess (for 3+ children)
variable ctc_social_security_excess:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "CTC Social Security Excess"
  description "Social security taxes minus EITC per Section 24(d)(1)(B)(ii)"

  formula:
    return max(0, social_security_taxes - earned_income_credit)

# Phase-in amount (greater of earnings or SS excess for 3+ children)
variable ctc_phase_in:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "CTC Phase-In Amount"
  description "Amount used to determine refundable credit"

  formula:
    if num_qualifying_children < qualifying_children_ss_threshold : ctc_phase_in_earnings
    else max(ctc_phase_in_earnings, ctc_social_security_excess)

# Maximum refundable amount per child
variable ctc_refundable_maximum:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "CTC Refundable Maximum"
  description "Maximum refundable amount based on number of qualifying children"

  formula:
    return num_qualifying_children * actc_refundable_maximum

# Refundable CTC (ACTC) - matches PolicyEngine logic
variable refundable_ctc:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "Refundable CTC (ACTC)"
  description "Refundable portion of CTC per Section 24(d)"

  formula:
    let ctc = total_child_tax_credit
    let phase_in = ctc_phase_in
    let limiting_tax = tax_liability_before_credits
    let max_refundable = ctc_refundable_maximum

    # How much CTC could be used if we had phase_in additional tax liability
    let ctc_capped_by_tax = min(ctc, limiting_tax)
    let ctc_capped_by_increased_tax = min(ctc, limiting_tax + phase_in)
    let amount_ctc_would_increase = ctc_capped_by_increased_tax - ctc_capped_by_tax

    # Refundable is limited by max refundable per child and by potential increase
    return min(min(max_refundable, ctc), amount_ctc_would_increase)

# Non-refundable CTC (for tax credit ordering)
variable non_refundable_ctc:
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "Non-Refundable CTC"
  description "Non-refundable portion of CTC"

  formula:
    return total_child_tax_credit - refundable_ctc
