# 26 USC § 24(c)(1) - Qualifying Child
#

text: """
The term 'qualifying child' means a qualifying child of the taxpayer
(as defined in section 152(c)) who has not attained age 17.
"""
variable qualifying_child:
  imports:
    - 26/152/c/is_qualifying_child#is_qualifying_child_152c
    - 26/24/c/1/qualifying_age_limit#qualifying_age_limit
  entity: TaxUnit
  period: Year
  dtype: Integer
  formula: |
    if not is_qualifying_child_152c : return false
    return age < qualifying_age_limit
