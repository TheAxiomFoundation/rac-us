# 26 USC § 61(a)(4) - Interest
#
# Gross income includes "interest."
# This includes taxable interest from bank accounts, bonds, loans, etc.

module statute.26.61.a.4
version "2024.1"

variable interest_income {
  entity Person
  period Year
  dtype Money
  unit "USD"
  label "Interest Income"
  description "Taxable interest income"
  reference "26 USC § 61(a)(4)"
  # Input from CPS: INT_VAL (interest income)
}
