# 26 USC § 61(a)(1) - Wages
#
# Gross income includes "compensation for services, including fees, commissions,
# fringe benefits, and similar items."

module statute.26.61.a.1
version "2024.1"

variable wages {
  entity Person
  period Year
  dtype Money
  unit "USD"
  label "Wages"
  description "Compensation for services as an employee"
  reference "26 USC § 61(a)(1)"
  # Input from CPS: WSAL_VAL (wage and salary income)
}
