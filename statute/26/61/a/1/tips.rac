# 26 USC § 61(a)(1) - Tips
#

text: """
Gross income includes "compensation for services, including fees, commissions,
fringe benefits, and similar items." Tips are includible in gross income.
"""
variable tips:
  entity: Person
  period: Year
  dtype: Money
  unit: "USD"
  label: "Tips"
  description: "Gratuities received for services"
