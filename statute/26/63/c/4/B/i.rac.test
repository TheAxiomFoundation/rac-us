# 26 USC 63(c)(4)(B)(i) tests

cola_base_year_standard_deduction:
    - name: "Base year is 1987 for taxable year 1989"
      period: 1989-01
      expect: 1987

    - name: "Base year is 1987 for taxable year 2000"
      period: 2000-01
      expect: 1987

    - name: "Base year is 1987 for taxable year 2024"
      period: 2024-01
      expect: 1987
