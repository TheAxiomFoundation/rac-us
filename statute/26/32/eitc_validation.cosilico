# 26 USC §32 - Earned Income Credit (Validation Version)
#
# Standalone encoding for validation against PolicyEngine.
# Uses PE's pre-computed eligibility and child count as inputs,
# then applies the §32(a) formula to compute the credit amount.
#
# This differs from the modular encoding which derives eligibility
# from person-level data through §32(c) references.
#
# 2024 parameters from Rev. Proc. 2023-34 (inflation adjustments)

module statute.26.32.validation
version "2024.1"

# Filing status values per §1
enum FilingStatus {
  SINGLE
  JOINT
  SEPARATE
  HEAD_OF_HOUSEHOLD
  SURVIVING_SPOUSE
}

# EITC parameters from §32(b) for 2024
# Credit percentage (phase-in rate) per §32(b)(1)
variable credit_percentage {
  entity TaxUnit
  period Year
  dtype Rate
  label "EITC Credit Percentage"
  description "Phase-in rate by number of qualifying children per §32(b)(1)"

  formula {
    let n_children = min(num_qualifying_children, 3)
    # 0 children: 7.65%, 1 child: 34%, 2 children: 40%, 3+ children: 45%
    return match n_children {
      case 0 => 0.0765
      case 1 => 0.34
      case 2 => 0.40
      case 3 => 0.45
      else => 0.45
    }
  }
}

# Phaseout percentage per §32(b)(1)
variable phaseout_percentage {
  entity TaxUnit
  period Year
  dtype Rate
  label "EITC Phaseout Percentage"
  description "Phase-out rate by number of qualifying children per §32(b)(1)"

  formula {
    let n_children = min(num_qualifying_children, 3)
    # 0 children: 7.65%, 1 child: 15.98%, 2+ children: 21.06%
    return match n_children {
      case 0 => 0.0765
      case 1 => 0.1598
      else => 0.2106
    }
  }
}

# Earned income amount (phase-in cap) per Rev Proc 2023-34 for 2024
# These are computed as max_credit / rate
variable earned_income_amount {
  entity TaxUnit
  period Year
  dtype Money
  label "EITC Earned Income Amount"
  description "Maximum earned income for phase-in calculation per Rev Proc 2023-34"

  formula {
    let n_children = min(num_qualifying_children, 3)
    # 2024 values: 0 children=$8,260, 1 child=$12,390, 2+=$17,400
    return match n_children {
      case 0 => 8260
      case 1 => 12390
      else => 17400
    }
  }
}

# Phaseout threshold per Rev Proc 2023-34 for 2024 (single/HoH)
variable phaseout_amount {
  entity TaxUnit
  period Year
  dtype Money
  label "EITC Phaseout Threshold"
  description "Income threshold where phaseout begins per Rev Proc 2023-34"

  formula {
    let n_children = min(num_qualifying_children, 3)
    # 2024 values: 0 children=$10,330, 1+=$22,720
    return match n_children {
      case 0 => 10330
      else => 22720
    }
  }
}

variable eitc_phase_in {
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "EITC Phase-In Amount"
  description "Credit percentage of earned income up to the cap per §32(a)(2)(A)"

  formula {
    # Credit = rate × min(earned_income, cap)
    return credit_percentage * min(earned_income, earned_income_amount)
  }
}

variable eitc_phase_out {
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "EITC Phase-Out Reduction"
  description "Reduction based on income exceeding threshold per §32(a)(2)(B)"

  formula {
    # Use the greater of AGI or earned income per §32(a)(2)(B)
    let income = max(adjusted_gross_income, earned_income)

    # Joint return adjustment per §32(b)(2)(B), indexed per Rev Proc 2023-34
    # 2024 value: $6,920 for joint filers
    let joint_adjustment = 6920

    # Joint filers get higher threshold per §32(b)(2)(B)
    let adjusted_threshold = if filing_status == JOINT then
      phaseout_amount + joint_adjustment
    else
      phaseout_amount

    # Reduction = rate × (income - threshold), but not below zero
    return max(0, phaseout_percentage * (income - adjusted_threshold))
  }
}

variable earned_income_credit {
  entity TaxUnit
  period Year
  dtype Money
  unit "USD"
  label "Earned Income Tax Credit"
  description "Refundable credit for low-to-moderate income working individuals per 26 USC 32(a)(1)"
  reference (
    "26 USC 32(a)(1)",
    "26 USC 32(c)(1)",
    "26 USC 32(d)",
    "26 USC 32(i)"
  )

  formula {
    # Use is_eligible_individual which checks all requirements:
    # - 32(c)(1)(A): qualifying children or meets childless requirements (age, abode)
    # - 32(c)(1)(B): not a qualifying child of another taxpayer
    # - 32(c)(1)(C): no foreign earned income exclusion
    # - 32(c)(1)(D): not a nonresident alien
    # - 32(c)(1)(E): valid SSN for taxpayer and spouse
    # - 32(d): not married filing separately
    # - 32(i): disqualified income under limit
    if not is_eligible_individual then
      return 0

    # Credit = phase-in minus phase-out, but not below zero
    return max(0, eitc_phase_in - eitc_phase_out)
  }
}
