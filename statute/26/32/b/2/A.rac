# 26 USC §32(b)(2)(A) - AGI Limit
variable agi_limit:
  entity: TaxUnit
  period: Year
  dtype: Money

# 26 USC §32(b)(2)(A) - Earned Income Amount
variable earned_income_amount:
  entity: TaxUnit
  period: Year
  dtype: Money

# 26 USC §32(b)(2)(A) - Phaseout Amount
variable phaseout_amount:
  entity: TaxUnit
  period: Year
  dtype: Money