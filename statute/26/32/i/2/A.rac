# 26 USC 32(i)(2)(A) - Interest and Dividends
#

text: """
(A) interest or dividends to the extent includible in gross income for
the taxable year
"""

input taxable_interest_dividends:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: "USD"
  label: "Taxable Interest and Dividends"
  description: "Interest and dividends includible in gross income per 26 USC 32(i)(2)(A)"
  default: 0
