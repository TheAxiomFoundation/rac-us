# 26 USC 32(i)(2)(B) - Tax-Exempt Interest
#

text: """
(B) interest received or accrued during the taxable year which is exempt
from tax imposed by this chapter
"""

input tax_exempt_interest:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: "USD"
  label: "Tax-Exempt Interest"
  description: "Tax-exempt interest income per 26 USC 32(i)(2)(B)"
  default: 0
