# Deductions for losses from sales or exchanges of property.

text: """
(4) Losses from sale or exchange of property.—The deductions allowed
by part VI (sec. 161 and following) as losses from the sale or exchange
of property.
"""

variable loss_deduction:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: USD
  label: "Loss Deduction"
  description: "Above-the-line deduction for losses from property sales per 26 USC 62(a)(4)"
