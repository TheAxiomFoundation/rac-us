# 26 USC 3304(a)(4)-(7) - Unemployment Insurance Eligibility
#
variable eligibility:
  imports:
    - 26/3304/parameters/waiting_period_weeks#waiting_period_weeks
    - 26/3304/parameters/extended_benefits_weeks#extended_benefits_weeks
    - 26/3304/parameters/extended_benefits_high_unemployment_weeks#extended_benefits_high_unemployment_weeks
    - 26/3304/benefit_computation/standard_maximum_weeks#standard_maximum_weeks
    - 26/3304/benefit_computation/base_period_wages_cap_rate#base_period_wages_cap_rate
    - 26/3304/benefit_computation/earnings_disregard_rate#earnings_disregard_rate
  entity: Person
  period: Year
  dtype: Integer
  unit: "USD"
  label: "Extended benefits weeks"
  description: "Additional weeks available under extended benefits"
  formula: |
    # Standard base period: first 4 of last 5 completed calendar quarters
    # States may also offer "alternate base period" using most recent 4 quarters
    # This calculation would typically use quarterly wage data
    return base_period_wages
  default: 0
