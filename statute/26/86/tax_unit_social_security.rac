# 26 USC Section 86 - Tax Unit Social Security Benefits
#

text: """
- 26 USC Section 86(d) - "social security benefit" definition
"""
variable tax_unit_social_security:
  entity: TaxUnit
  period: Year
  dtype: Money
  unit: "USD"
  label: "Total Social Security Benefits Received"
  description: "Sum of Social Security and tier 1 railroad retirement benefits received by tax unit members per 26 USC Section 86(d)"
  default: 0
