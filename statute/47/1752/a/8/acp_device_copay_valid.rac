# 47 USC 1752(a)(8)(A) - ACP Device Copay Validation
#

text: """
...if the charge to such eligible household is more than $10
but less than $50 for such connected device...
"""
variable acp_device_copay_valid:
  imports:
    - 47/1752/parameters/connected_device/min_copay#min_copay
    - 47/1752/parameters/connected_device/max_copay#max_copay
  entity: Household
  period: Month
  dtype: Boolean
  label: "ACP Device Copay Valid"
  description: "Device copay is more than $10 but less than $50 per 47 USC 1752(a)(8)"
  formula: |
    # Copay must be > $10 and < $50
    copay = connected_device_copay
    return copay > min_copay and copay < max_copay
  default: false
