snap_usda_cola_federal_full_month_benefit:
    - name: "FY2026 bundle yields the expected full-month federal benefit for an eligible contiguous household"
      period: 2026-10
      inputs:
        snap_region: CONTIGUOUS_US
        snap_household_size: 4
        snap_non_self_employment_income: 1056
        snap_total_resources_before_exclusions: 2500
        snap_household_meets_other_federal_eligibility_requirements: true
      expect: 744

    - name: "FY2026 bundle yields zero full-month benefit when the household fails the resource test"
      period: 2026-10
      inputs:
        snap_region: CONTIGUOUS_US
        snap_household_size: 4
        snap_non_self_employment_income: 1056
        snap_total_resources_before_exclusions: 3001
        snap_household_meets_other_federal_eligibility_requirements: true
      expect: 0

snap_usda_cola_issuance_month_benefit:
    - name: "FY2026 bundle prorates the initial-month benefit from the eligible full-month amount"
      period: 2026-10
      inputs:
        snap_region: CONTIGUOUS_US
        snap_household_size: 4
        snap_non_self_employment_income: 1056
        snap_total_resources_before_exclusions: 2500
        snap_household_meets_other_federal_eligibility_requirements: true
        snap_is_initial_month: true
        snap_initial_month_days_remaining: 12
        snap_initial_month_total_days: 31
      expect: 288

snap_usda_cola_combined_initial_and_next_month_allotment:
    - name: "FY2026 bundle combines initial and following month allotments for expedited households after the fifteenth"
      period: 2026-10
      inputs:
        snap_region: CONTIGUOUS_US
        snap_household_size: 4
        snap_non_self_employment_income: 1056
        snap_total_resources_before_exclusions: 2500
        snap_household_meets_other_federal_eligibility_requirements: true
        snap_is_initial_month: true
        snap_application_day_of_month: 20
        snap_state_issues_combined_initial_and_next_month_allotment: true
        snap_initial_month_days_remaining: 12
        snap_initial_month_total_days: 31
      expect: 1032
